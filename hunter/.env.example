# ── Chartmetric (free tier) ───────────────────────────────────────────────────
# Sign up at https://chartmetric.com → get refresh token from API settings
# Used for: popularity filter (only target tracks with Spotify popularity > 60)
CHARTMETRIC_REFRESH_TOKEN=your_chartmetric_refresh_token_here

# ── Hunter.io (free tier = 25 searches/month) ─────────────────────────────────
# Sign up at https://hunter.io → API Keys section
# Used for: finding artist manager / label A&R email for outreach
HUNTER_API_KEY=your_hunter_api_key_here

# ── Proxies (residential, for SoundExchange stealth probe) ───────────────────
# Recommended: webshare.io ~$5/mo for 10 residential IPs
# Format: http://user:pass@host:port  (comma separated for multiple)
PROXIES=http://user:pass@proxy1.webshare.io:8080,http://user:pass@proxy2.webshare.io:8080

# ── No Spotify key needed. No YouTube API key needed. ─────────────────────────
